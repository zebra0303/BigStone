# Server Configuration
PORT=3001

# Frontend Configuration (Variables exposed to the client must start with VITE_)
VITE_PORT=3000
VITE_API_URL=/api

# Security
# openssl rand -base64 32 to generate a random secret key
JWT_SECRET=your_secret_key_here
# CORS_ORIGIN=http://mydomain,http://localhost:3000
CORS_ORIGIN=http://localhost:3000

