{
  "name": "bigstone",
  "version": "1.0.0",
  "description": "BigStone Task Manager",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "concurrently \"npm run start -w server\" \"npm run preview -w client\"",
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "install:all": "npm install",
    "build": "npm run build -w client && npm run build -w server",
    "test": "npm run test -w client && npm run test -w server",
    "prepare": "husky"
  },
  "lint-staged": {
    "client/src/**/*.{ts,tsx}": [
      "eslint --no-warn-ignored",
      "prettier --check"
    ],
    "server/src/**/*.ts": [
      "prettier --check"
    ],
    "*.{json,md,css}": [
      "prettier --check"
    ]
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
